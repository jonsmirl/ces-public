&CONTROL
  calculation = 'scf'
  prefix = 'mgb2h2'
  pseudo_dir = '/usr/share/espresso/pseudo/'
  outdir = './tmp/'
  tprnfor = .true.
  tstress = .true.
/
&SYSTEM
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
  nosym = .true.
  la2F = .true.
/
&ELECTRONS
  conv_thr = 1.0d-10
  mixing_beta = 0.5
/
