&CONTROL
  calculation = 'scf'
  prefix = 'mgb2h2'
  pseudo_dir = '/usr/share/espresso/pseudo/'
  outdir = './tmp/'
  tprnfor = .true.
  tstress = .true.
/
&SYSTEM
  ibrav = 0
  nat = 5
  ntyp = 3
  ecutwfc = 60.0
  ecutrho = 480.0
  occupations = 'smearing'
  smearing = 'mp'
  degauss = 0.02
/
&ELECTRONS
  conv_thr = 1.0d-10
  mixing_beta = 0.5
/
CELL_PARAMETERS {angstrom}
  3.086000  0.000000  0.000000
 -1.543000  2.671995  0.000000
  0.000000  0.000000  5.000000

ATOMIC_SPECIES
  Mg  24.305  Mg.pbe-n-kjpaw_psl.0.3.0.UPF
  B   10.811  B.pbe-n-kjpaw_psl.1.0.0.UPF
  H    1.008  H.pbe-kjpaw.UPF

ATOMIC_POSITIONS {crystal}
  Mg  0.000000  0.000000  0.000000
  B   0.333333  0.666667  0.450000
  B   0.666667  0.333333  0.450000
  H   0.333333  0.666667  0.690000
  H   0.666667  0.333333  0.690000

K_POINTS {automatic}
  12 12 8  0 0 0
